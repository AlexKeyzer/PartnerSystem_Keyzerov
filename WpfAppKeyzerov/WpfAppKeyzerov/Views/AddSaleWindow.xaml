<Window x:Class="Keyzerov.WPF.Views.AddSaleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление продажи" Height="300" Width="400"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Наименование продукции:" Margin="0,0,0,5"/>
            <TextBox Text="{Binding ProductName}" Height="30" Margin="0,0,0,15"/>

            <TextBlock Text="Количество:" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Quantity}" Height="30" Margin="0,0,0,15"/>

            <TextBlock Text="Дата продажи:" Margin="0,0,0,5"/>
            <DatePicker SelectedDate="{Binding SaleDate}" Height="30" Margin="0,0,0,15"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Отмена" Width="100" Height="35" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Content="Сохранить" Width="100" Height="35" Background="#4CAF50" Foreground="White" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>