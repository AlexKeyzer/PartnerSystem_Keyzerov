<Window x:Class="Keyzerov.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keyzerov - Управление партнерами" 
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="Партнеры">
                <MenuItem Header="Добавить" Command="{Binding AddPartnerCommand}"/>
                <MenuItem Header="Редактировать" Command="{Binding EditPartnerCommand}"/>
                <MenuItem Header="Удалить" Command="{Binding DeletePartnerCommand}"/>
            </MenuItem>
            <MenuItem Header="Продажи">
                <MenuItem Header="Добавить продажу" Command="{Binding AddSaleCommand}"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="0,5,5,5">
                <ListBox x:Name="LstPartners" 
                         ItemsSource="{Binding Partners}" 
                         SelectedItem="{Binding SelectedPartner}"
                         SelectionMode="Single">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10" Background="White">
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" FontSize="14">
                                        <Run Text="{Binding Type.TypeName, FallbackValue=''}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding Name}"/>
                                    </TextBlock>

                                    <TextBlock Text="{Binding DirectorName}" FontSize="12" Foreground="Gray" Margin="0,2,0,0"/>

                                    <TextBlock Text="{Binding Phone}" FontSize="12" Margin="0,2,0,0"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock Text="Рейтинг: " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Rating}"/>
                                        <TextBlock Text=" | Скидка: " FontWeight="Bold" Margin="10,0,0,0"/>
                                        <TextBlock Text="{Binding CurrentDiscount, StringFormat={}{0}%}" Foreground="Green"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="5,5,0,5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="5" FontWeight="Bold">
                        <Run Text="История продаж: "/>
                        <Run Text="{Binding SelectedPartner.Name, FallbackValue='(не выбран)'}"/>
                    </TextBlock>

                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding SalesHistory}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding SaleDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Продукция" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="1" VerticalAlignment="Bottom">
            <TextBlock Text="{Binding StatusMessage}"/>
        </StatusBar>
    </Grid>
</Window>